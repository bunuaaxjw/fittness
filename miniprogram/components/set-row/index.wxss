/* components/set-row/index.wxss */
.set-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 6rpx 0;
}

.set-row--done {
  background: #eafaf1;
  border-radius: 8rpx;
}

.set-col--num {
  width: 36rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  flex-shrink: 0;
}

.set-row--done .set-col--num {
  color: #27ae60;
  font-weight: 600;
}

/* 重量/次数输入框 */
.set-input {
  width: 120rpx;
  flex: none;
  background: #f5f5f5;
  border-radius: 6rpx;
  padding: 8rpx 4rpx;
  font-size: 24rpx;
  text-align: center;
  margin: 0 4rpx;
}

/* 完成按钮框 — 和输入框统一风格 */
.set-toggle-box {
  width: 72rpx;
  height: 44rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 4rpx;
  flex-shrink: 0;
}

.set-toggle-box--done {
  background: #f5f5f5;
}

.set-toggle-check {
  font-size: 24rpx;
  color: #333;
  font-weight: 700;
}

/* 更多菜单列（垂直布局：休息时间在上，...在下） */
.set-col--more-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 36rpx;
  flex-shrink: 0;
}

.set-col--rest-timer {
  font-size: 18rpx;
  color: #27ae60;
  white-space: nowrap;
}

.set-col--more {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1;
}

/* ===== 弹窗通用 ===== */
.notes-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.notes-modal {
  width: 560rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.notes-modal-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

/* ===== 备注弹窗 ===== */
.notes-textarea {
  width: 100%;
  height: 140rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.notes-actions {
  display: flex;
  gap: 16rpx;
}

.notes-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  padding: 0;
  border: none;
}

.notes-btn::after { border: none; }

.notes-btn--cancel {
  background: #f0f0f0;
  color: #666;
}

.notes-btn--confirm {
  background: #e94560;
  color: #fff;
}

/* ===== 休息时间选择 ===== */
.rest-picker {
  padding-bottom: 24rpx;
}

.rest-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  justify-content: center;
}

.rest-opt {
  width: 140rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rest-opt-val {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}
