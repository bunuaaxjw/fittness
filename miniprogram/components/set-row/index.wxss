/* components/set-row/index.wxss */
.set-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 4rpx 0;
}

/* 行号 */
.set-col--num {
  width: 32rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  flex-shrink: 0;
  margin-right: 8rpx;
}

/* 方形输入框 */
.set-square {
  width: 100rpx;
  height: 100rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  margin: 0 6rpx;
  flex-shrink: 0;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.set-square-label {
  position: absolute;
  top: 6rpx;
  left: 8rpx;
  font-size: 18rpx;
  color: #999;
  line-height: 1;
}

.set-square-input {
  width: 100%;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding: 0 4rpx 12rpx;
  min-height: auto;
}

/* 完成状态 — 方形框变绿 */
.set-square--done {
  background: #d5f5e3;
}

.set-square--toggle {
  align-items: center;
}

.set-square--done.set-square--toggle {
  background: #27ae60;
}

/* 完成按钮文字 */
.set-toggle-empty {
  font-size: 36rpx;
  color: #ccc;
  line-height: 1;
}

.set-toggle-check {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

/* 更多菜单列（自动右对齐） */
.set-col--more-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
  margin-left: auto;
}

.set-col--rest-timer {
  font-size: 18rpx;
  color: #27ae60;
  white-space: nowrap;
  line-height: 1.2;
}

.set-col--more {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1;
}

/* ===== 弹窗 ===== */
.notes-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000;
}
.notes-modal {
  width: 560rpx; background: #fff; border-radius: 16rpx; padding: 32rpx;
}
.notes-modal-title {
  display: block; font-size: 30rpx; font-weight: 600; color: #333;
  margin-bottom: 20rpx; text-align: center;
}
.notes-textarea {
  width: 100%; height: 140rpx; background: #f5f5f5; border-radius: 8rpx;
  padding: 16rpx; font-size: 26rpx; box-sizing: border-box; margin-bottom: 24rpx;
}
.notes-actions { display: flex; gap: 16rpx; }
.notes-btn {
  flex: 1; height: 72rpx; line-height: 72rpx; text-align: center;
  border-radius: 36rpx; font-size: 28rpx; padding: 0; border: none;
}
.notes-btn::after { border: none; }
.notes-btn--cancel { background: #f0f0f0; color: #666; }
.notes-btn--confirm { background: #e94560; color: #fff; }
.rest-picker { padding-bottom: 24rpx; }
.rest-options { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; justify-content: center; }
.rest-opt {
  width: 140rpx; height: 72rpx; background: #f5f5f5; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
}
.rest-opt-val { font-size: 28rpx; color: #333; font-weight: 600; }
