<!-- components/set-row/index.wxml -->
<view class="set-row {{completed ? 'set-row--done' : ''}}">
  <text class="set-col--num">{{setIndex + 1}}</text>

  <input
    class="set-input {{completed ? 'set-input--done' : ''}}"
    type="digit"
    placeholder="0"
    value="{{weight}}"
    data-field="weight_kg"
    bindinput="onInput"
  />
  <input
    class="set-input {{completed ? 'set-input--done' : ''}}"
    type="number"
    placeholder="0"
    value="{{reps}}"
    data-field="reps"
    bindinput="onInput"
  />

  <!-- 完成按钮：未完成=空心框，完成=绿底白✓ -->
  <view class="set-toggle-box {{completed ? 'set-toggle-box--done' : ''}}" bindtap="onToggleComplete">
    <text wx:if="{{completed}}" class="set-toggle-check">✓</text>
  </view>

  <!-- 更多菜单列 -->
  <view class="set-col--more-wrap">
    <text
      wx:if="{{completed && restSeconds > 0}}"
      class="set-col--rest-timer"
    >{{restTimerText}}</text>
    <text
      wx:if="{{showMoreMenu}}"
      class="set-col--more"
      bindtap="onMore"
    >⋯</text>
  </view>
</view>

<!-- 备注编辑弹窗 -->
<view wx:if="{{showNotesModal}}" class="notes-overlay" bindtap="onNotesCancel">
  <view class="notes-modal" catchtap="">
    <text class="notes-modal-title">备注</text>
    <textarea class="notes-textarea" value="{{editingNotes}}" placeholder="输入备注..." bindinput="onNotesInput" maxlength="50"/>
    <view class="notes-actions">
      <button class="notes-btn notes-btn--cancel" bindtap="onNotesCancel">取消</button>
      <button class="notes-btn notes-btn--confirm" bindtap="onNotesConfirm">确认</button>
    </view>
  </view>
</view>

<!-- 休息时间选择弹窗 -->
<view wx:if="{{showRestModal}}" class="notes-overlay" bindtap="onRestCancel">
  <view class="notes-modal rest-picker" catchtap="">
    <text class="notes-modal-title">组间休息时长</text>
    <view class="rest-options">
      <view class="rest-opt" data-seconds="30" bindtap="onRestSelect"><text class="rest-opt-val">30s</text></view>
      <view class="rest-opt" data-seconds="60" bindtap="onRestSelect"><text class="rest-opt-val">60s</text></view>
      <view class="rest-opt" data-seconds="90" bindtap="onRestSelect"><text class="rest-opt-val">90s</text></view>
      <view class="rest-opt" data-seconds="120" bindtap="onRestSelect"><text class="rest-opt-val">120s</text></view>
      <view class="rest-opt" data-seconds="180" bindtap="onRestSelect"><text class="rest-opt-val">180s</text></view>
    </view>
    <button class="notes-btn notes-btn--cancel" bindtap="onRestCancel">取消</button>
  </view>
</view>
