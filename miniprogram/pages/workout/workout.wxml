<!-- pages/workout/workout.wxml — 训练页 -->
<view class="container">
  <view wx:if="{{!isWorkoutActive}}" class="workout-start card text-center">
    <text class="start-icon">🏋️</text>
    <text class="start-title">准备开始训练</text>
    <text class="start-desc">记录你的每一次进步</text>
    <button class="btn-primary" bindtap="startWorkout">开始新训练</button>
  </view>

  <view wx:if="{{isWorkoutActive && state}}">
    <view class="card timer-card flex-between">
      <view><text class="timer-label">训练时长</text><text class="timer-value">{{timerText}}</text></view>
      <text class="timer-badge">进行中</text>
    </view>

    <exercise-card
      wx:for="{{state.exercises}}"
      wx:key="exercise._id"
      name="{{item.exercise.name}}"
      body-part="{{item.exercise.body_part}}"
      icon="{{item.exercise.icon}}"
      gif-url="{{item.exercise.gif_url}}"
      instructions-zh="{{item.exercise.instructions_zh}}"
      sets="{{item.sets}}"
      exercise-index="{{index}}"
      show-remove="{{true}}"
      bind:addset="onAddSet"
      bind:setupdate="onSetUpdate"
      bind:setremove="onSetRemove"
      bind:removeexercise="onRemoveExercise"
      bind:settogglecomplete="onSetToggleComplete"
      bind:setrestchange="onSetRestChange"
      bind:setduplicate="onSetDuplicate"
    />

    <view class="workout-actions">
      <button class="btn-outline" bindtap="openExercisePicker">+ 添加动作</button>
      <button class="btn-primary" bindtap="finishWorkout" loading="{{saving}}">完成训练</button>
    </view>
  </view>

  <!-- 倒计时弹窗 -->
  <view wx:if="{{rtVisible && !rtMinimized}}" class="rest-overlay">
    <view class="rest-modal">
      <view class="rest-modal-header">
        <text></text>
        <text class="rest-minimize-btn" bindtap="onRestMinimize">— 最小化</text>
      </view>
      <text class="rest-exercise-label">{{rtExercise}} 第 {{rtSetIndex + 1}} 组</text>
      <text class="rest-countdown">{{rtDisplay}}</text>
      <view class="rest-actions">
        <button class="rest-btn rest-btn--add" bindtap="onRestAdd10">＋10s</button>
        <button class="rest-btn rest-btn--skip" bindtap="onRestSkip">跳过</button>
        <button class="rest-btn rest-btn--sub" bindtap="onRestSub10">−10s</button>
      </view>
      <text class="rest-hint">组间休息，下一组准备...</text>
    </view>
  </view>

  <view wx:if="{{rtVisible && rtMinimized}}" class="rest-minibar">
    <text class="rest-minibar-text">⏱ 组间休息 {{rtDisplay}}</text>
    <text class="rest-minibar-expand" bindtap="onRestExpand">展开</text>
  </view>
</view>
