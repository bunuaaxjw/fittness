/* pages/workout/workout.wxss — 训练页样式 */

/* ===== 引导页 ===== */
.workout-start {
  padding: 120rpx 24rpx 80rpx;
}

.start-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.start-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.start-desc {
  display: block;
  color: #999;
  font-size: 28rpx;
  margin-bottom: 48rpx;
}

/* ===== 计时器卡片 ===== */
.timer-card {
  padding: 32rpx 28rpx;
}

.timer-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.timer-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #e94560;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.timer-badge {
  background-color: #e94560;
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

/* ===== 底部操作 ===== */
.workout-actions {
  margin-top: 8rpx;
}

.workout-actions .btn-outline {
  width: 100%;
  margin-bottom: 20rpx;
}

.workout-actions .btn-primary {
  width: 100%;
}
