/* pages/history/history.wxss — 记录页样式 */

/* ===== 搜索栏 ===== */
.search-bar {
  margin: 10rpx 0 10rpx;
}

.search-bar input {
  width: 100%;
  height: 68rpx;
  line-height: 68rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* ===== 空状态 ===== */
.empty-card {
  padding: 100rpx 24rpx;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  display: block;
  color: #666;
  font-size: 28rpx;
}

.empty-desc {
  display: block;
  color: #999;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ===== 日期标题 ===== */
.date-header {
  padding: 24rpx 8rpx 12rpx;
}

.date-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.date-count {
  font-size: 24rpx;
  color: #999;
}

/* ===== 训练卡片 ===== */
.history-card {
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.history-main {
  display: flex;
  flex-direction: column;
}

.history-duration {
  font-size: 32rpx;
  font-weight: 700;
  color: #e94560;
}

.history-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.history-exercises {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 360rpx;
}

.history-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.history-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.history-delete {
  font-size: 28rpx;
  color: #ccc;
  padding: 12rpx;
}

/* ===== 加载更��� ===== */
.load-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.load-end {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #ccc;
}
