/* pages/index/index.wxss — 首页样式 */

/* ===== 今日卡片 ===== */
.today-card {
  padding: 28rpx;
}

.today-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.weekly-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* ===== 今日状态 ===== */
.today-body {
  text-align: center;
  padding: 40rpx 0;
}

.today-body .btn-primary {
  display: inline-block;
}

.today-empty-text {
  display: block;
  color: #666;
  margin-bottom: 24rpx;
}

.today-body--done {
  padding: 32rpx 0 16rpx;
}

.today-done-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.today-done-text {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.today-done-detail {
  display: block;
  font-size: 24rpx;
  color: #e94560;
  margin-top: 8rpx;
}

.today-done-exercises {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ===== 最近训练 ===== */
.recent-item {
  padding: 20rpx 0;
}

.recent-left {
  display: flex;
  flex-direction: column;
}

.recent-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.recent-duration {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.recent-exercises {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.recent-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* ===== 空状态 ===== */
.empty-card {
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}
