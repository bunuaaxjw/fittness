/* pages/history-detail/index.wxss — 历史训练详情页样式 */

/* ===== 概览卡片 ===== */
.summary-card {
  padding: 28rpx;
}

.summary-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.summary-date {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.summary-duration {
  font-size: 36rpx;
  font-weight: 700;
  color: #e94560;
}

/* ===== 动作卡片 ===== */
.exercise-card {
  padding: 24rpx 28rpx 20rpx;
}

.detail-ex-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

/* ===== 组列头 ===== */
.set-header {
  padding: 8rpx 0;
}

.set-head-col {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.set-head-col--num {
  width: 60rpx;
}

.set-head-col--weight {
  flex: 1;
}

.set-head-col--reps {
  flex: 1;
}

.set-head-col--notes {
  flex: 1.5;
}

/* ===== 组记录行 ===== */
.set-row {
  margin-bottom: 16rpx;
  align-items: center;
}

.set-cell {
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.set-cell--num {
  width: 60rpx;
  color: #999;
  font-size: 26rpx;
}

.set-cell--weight {
  flex: 1;
}

.set-cell--reps {
  flex: 1;
}

.set-cell--notes {
  flex: 1.5;
  color: #666;
  font-size: 24rpx;
}

/* ===== 备注 ===== */
.notes-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.notes-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* ===== 再来一次按钮 ===== */
.btn-again {
  width: 100%;
  margin-top: 32rpx;
}
