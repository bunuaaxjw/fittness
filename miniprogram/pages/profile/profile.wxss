/* pages/profile/profile.wxss — 个人中心样式 */

/* ===== 用户卡片 ===== */
.user-card {
  padding: 32rpx 28rpx;
}

.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 48rpx;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.user-info {
  margin-left: 24rpx;
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.user-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ===== 统计卡片 ===== */
.stats-card {
  padding: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.stats-row {
  display: flex;
  margin-top: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #e94560;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ===== 常用动作 ===== */
.section-header {
  margin-bottom: 20rpx;
}

.manage-btn {
  font-size: 26rpx;
  color: #e94560;
}

.empty-hint {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

.common-item {
  padding: 16rpx 0;
}

.common-item + .common-item {
  border-top: 1rpx solid #f5f5f5;
}

.common-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.common-count {
  font-size: 24rpx;
  color: #999;
}

/* ===== 版本 ===== */
.version-text {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #ccc;
}
