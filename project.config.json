{
  "description": "健身记录微信小程序",
  "miniprogramRoot": "miniprogram/",
  "cloudfunctionRoot": "cloudfunctions/",
  "packOptions": {
    "ignore": [
      {
        "value": "*.md",
        "type": "file"
      },
      {
        "value": "docs",
        "type": "folder"
      }
    ],
    "include": []
  },
  "setting": {
    "urlCheck": true,
    "es6": true,
    "enhance": true,
    "postcss": true,
    "preloadBackgroundData": false,
    "minified": true,
